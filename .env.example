# ct8114 本地开发环境变量
# 启动方式: 直接设置环境变量后运行 uvicorn

# 启用模拟共享卷（本地测试用）
MOCK_UNIPORTAL_DIR=mock_uniportal

# 启用模拟分析（本地测试用，无需 codetidy.exe）
MOCK_ANALYSIS=true

# UniPortal 相关（模拟模式下不需要设置）
# UNIPORTAL_STORAGE_PATH=/data/uniportal
# UNIPORTAL_WRITABLE=true

# 本地工作空间
LOCAL_WORKSPACES_DIR=workspaces

# 报告存储
REPORTS_DIR=workspaces/_reports
DSIT_REPORTS_DIR=workspaces/_dsit_reports

# 上传限制
MAX_TOTAL_BYTES=5242880
MAX_ZIP_BYTES=52428800
