# ct8114 本地开发环境变量
# 启动方式: 直接设置环境变量后运行 uvicorn

# 启用模拟共享卷（本地测试用，无需真实 UniPortal）
MOCK_UNIPORTAL_DIR=mock_uniportal

# 模拟分析模式（设为 true 时跳过 codetidy，用于纯前端测试）
# MOCK_ANALYSIS=true

# 分析引擎: dcab_http 调用 /start_progress + /check_progress; codetidy 保留为本地 fallback
ANALYSIS_ENGINE=dcab_http
DCAB_BASE_URL=http://127.0.0.1:8080
DCAB_START_PATH=/start_progress
DCAB_CHECK_PATH=/check_progress
DCAB_START_METHOD=POST
DCAB_CHECK_METHOD=POST
DCAB_REQUEST_TIMEOUT=15
DEEPSITR_WORKDIR=D:\齐景\静态分析工具\DeepSITRServer-2026-6-9\DeepSITRServer

# DeepSITRServer 安装根目录（推荐，程序自动查找 core/codetidy.exe）
# PowerShell: $env:DEEPSITR_ROOT="E:\path\to\DeepSITRServer"
# Linux:      export DEEPSITR_ROOT=/opt/DeepSITRServer
DEEPSITR_ROOT=

# codetidy.exe 完整路径（高级覆盖，设置后将优先于 DEEPSITR_ROOT）
# CODETIDY_BIN=E:\path\to\DeepSITRServer\core\codetidy.exe

# UniPortal 相关（模拟模式下不需要设置）
# UNIPORTAL_STORAGE_PATH=/data/uniportal
# UNIPORTAL_WRITABLE=true

# 本地工作空间
LOCAL_WORKSPACES_DIR=workspaces

# 报告存储
REPORTS_DIR=workspaces/_reports
DSIT_REPORTS_DIR=workspaces/_dsit_reports

# 上传限制
MAX_TOTAL_BYTES=5242880
MAX_ZIP_BYTES=52428800
